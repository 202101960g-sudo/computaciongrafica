<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gráfico de Línea Dinámica Animada</title>
    <style>
        body {
            font-family: sans-serif;
            text-align: center;
            margin-top: 20px;
        }
        .graph-title {
            font-size: 1.1em;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 10px;
        }
        canvas {
            border: 1px solid black;
            background-color: white;
            display: block;
            margin: 0 auto;
        }
    </style>
</head>
<body>

    <div class="graph-title">
        GRAFICO DE LINEA DINAMICA DESARROLLADO POR : YENNY CAMACHO
    </div>

    <canvas id="dynamicGraph" width="300" height="200"></canvas>

    <script>
        // Obtener el lienzo y su contexto
        const canvas = document.getElementById('dynamicGraph');
        const ctx = canvas.getContext('2d');

        // Configuración de la onda
        const amplitude = 40;  // Altura de la onda
        const frequency = 0.05; // Cuántas ondas por unidad de x
        let phase = 0;          // La fase que cambia para la animación
        let speed = 0.1;        // Velocidad de movimiento (cuánto cambia la fase por fotograma)

        // Función para dibujar los ejes
        function drawAxes() {
            ctx.beginPath();
            ctx.strokeStyle = 'lightgray'; // Ejes más claros
            ctx.lineWidth = 1;

            // Eje vertical (en el centro)
            ctx.moveTo(canvas.width / 2, 0);
            ctx.lineTo(canvas.width / 2, canvas.height);

            // Eje horizontal (en el centro)
            ctx.moveTo(0, canvas.height / 2);
            ctx.lineTo(canvas.width, canvas.height / 2);

            ctx.stroke();
        }

        // Función de animación principal
        function animate() {
            // Limpiar el lienzo para el nuevo fotograma
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Dibujar los ejes fijos
            drawAxes();

            // Configurar el estilo de la línea
            ctx.beginPath();
            ctx.strokeStyle = 'green';
            ctx.lineWidth = 2;

            // Dibujar la onda sinusoidal punto por punto
            let firstPoint = true;
            for (let x = 0; x < canvas.width; x++) {
                // Función matemática de la onda sinusoidal (sin)
                // Usamos la fase cambiante (phase) para crear movimiento
                const y = amplitude * Math.sin((x * frequency) + phase) + (canvas.height / 2);

                if (firstPoint) {
                    ctx.moveTo(x, y);
                    firstPoint = false;
                } else {
                    ctx.lineTo(x, y);
                }
            }

            // Dibujar la línea completa
            ctx.stroke();

            // Actualizar la fase para el siguiente fotograma para crear movimiento
            phase -= speed; // Restar mueve la onda hacia la derecha, sumar la mueve hacia la izquierda

            // Solicitar el siguiente fotograma de animación
            requestAnimationFrame(animate);
        }

        // Iniciar la animación
        animate();

    </script>
</body>
</html>
